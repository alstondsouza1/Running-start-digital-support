# Server
PORT=5001

# Auth
ADMIN_USERNAME=admin

# Generate with bcrypt before deployment.
# Example:
# node -e "import bcrypt from 'bcryptjs'; console.log(await bcrypt.hash('yourpassword', 12));"
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Use a long random value in production.
JWT_SECRET=replace_with_long_random_secret

# Database
DB_HOST=replace_with_database_host
DB_PORT=3306
DB_USER=replace_with_database_user
DB_PASSWORD=replace_with_database_password
DB_NAME=replace_with_database_name

# SSL
# Use DB_SSL=false for most local MySQL setups.
# Use DB_SSL=true for hosted databases that require SSL.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Frontend origins allowed to call backend
CORS_ORIGINS=http://localhost:5173,https://running-start-portal.vercel.app
