# Server
PORT=5001

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
JWT_SECRET=replace_with_long_random_secret

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace_with_db_password
DB_NAME=runningstart

# SSL
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Frontend origins allowed to call backend
CORS_ORIGINS=http://localhost:5173,https://running-start-portal.vercel.app